{
  "name": "rifago",
  "version": "1.0.0",
  "description": "RifaGo - Sistema de Gestión de Rifas y Sorteos en Línea",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "npm run build:css && node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/style.css",
    "watch:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/style.css --watch"
  },
  "keywords": [
    "raffle",
    "rifas",
    "sorteos",
    "express",
    "socket.io",
    "mongoose"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.1.0",
    "firebase-admin": "^12.1.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.2.0",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "nodemon": "^3.1.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  }
}
