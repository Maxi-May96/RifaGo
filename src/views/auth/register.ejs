<div class="max-w-md mx-auto my-12 bg-white rounded-3xl border border-borderCustom shadow-xl overflow-hidden p-8">
  <div class="text-center mb-8">
    <div class="inline-flex w-16 h-16 rounded-2xl bg-secondary/10 items-center justify-center mb-4">
      <span class="text-3xl text-secondary">👤</span>
    </div>
    <h2 class="text-3xl font-extrabold text-dark tracking-tight">Crear Cuenta</h2>
    <p class="text-sm text-slate-500 mt-2">Únete a RifaGo y comienza a participar en increíbles sorteos</p>
  </div>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm font-semibold p-4 rounded-xl mb-6 flex items-center space-x-2">
      <span>⚠️</span>
      <span><%= error %></span>
    </div>
  <% } %>

  <form action="/auth/register" method="POST" class="space-y-5">
    <div>
      <label for="name" class="block text-sm font-bold text-dark mb-2">Nombre Completo</label>
      <input type="text" id="name" name="name" required placeholder="Tu nombre" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <div>
      <label for="email" class="block text-sm font-bold text-dark mb-2">Correo Electrónico</label>
      <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <div>
      <label for="password" class="block text-sm font-bold text-dark mb-2">Contraseña</label>
      <input type="password" id="password" name="password" required placeholder="Mínimo 6 caracteres" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <div>
      <label for="confirmPassword" class="block text-sm font-bold text-dark mb-2">Confirmar Contraseña</label>
      <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Repite tu contraseña" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <button type="submit" class="w-full bg-gradient-to-r from-primary to-primary-light hover:from-primary-light hover:to-primary text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-primary/30 transition-all duration-300 mt-2">
      Crear Cuenta
    </button>
  </form>

  <div class="text-center mt-8 pt-6 border-t border-borderCustom/60">
    <p class="text-sm text-slate-600">
      ¿Ya tienes una cuenta? 
      <a href="/auth/login" class="font-bold text-primary hover:text-primary-light transition-colors">Inicia sesión aquí</a>
    </p>
  </div>
</div>
