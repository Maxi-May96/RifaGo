<div class="max-w-md mx-auto my-12 bg-white rounded-3xl border border-borderCustom shadow-xl overflow-hidden p-8">
  <div class="text-center mb-8">
    <div class="inline-flex w-16 h-16 rounded-2xl bg-primary/10 items-center justify-center mb-4">
      <span class="text-3xl text-primary">🔑</span>
    </div>
    <h2 class="text-3xl font-extrabold text-dark tracking-tight">Iniciar Sesión</h2>
    <p class="text-sm text-slate-500 mt-2">Ingresa a tu cuenta de RifaGo para comprar boletos y ver tus sorteos</p>
  </div>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm font-semibold p-4 rounded-xl mb-6 flex items-center space-x-2">
      <span>⚠️</span>
      <span><%= error %></span>
    </div>
  <% } %>

  <form action="/auth/login" method="POST" class="space-y-6">
    <div>
      <label for="email" class="block text-sm font-bold text-dark mb-2">Correo Electrónico</label>
      <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <div>
      <div class="flex justify-between items-center mb-2">
        <label for="password" class="block text-sm font-bold text-dark">Contraseña</label>
        <a href="/auth/recover" class="text-xs font-semibold text-primary hover:text-primary-light transition-colors">¿Olvidaste tu contraseña?</a>
      </div>
      <input type="password" id="password" name="password" required placeholder="••••••••" 
             class="w-full px-4 py-3 rounded-xl border border-borderCustom focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
    </div>

    <button type="submit" class="w-full bg-gradient-to-r from-primary to-primary-light hover:from-primary-light hover:to-primary text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-primary/30 transition-all duration-300">
      Ingresar
    </button>
  </form>

  <div class="text-center mt-8 pt-6 border-t border-borderCustom/60">
    <p class="text-sm text-slate-600">
      ¿No tienes una cuenta? 
      <a href="/auth/register" class="font-bold text-primary hover:text-primary-light transition-colors">Regístrate aquí</a>
    </p>
  </div>
</div>
