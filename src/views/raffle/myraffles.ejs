  <div class="bg-white rounded-3xl max-w-md w-full border border-borderCustom shadow-2xl overflow-hidden flex flex-col animate-fade-in relative">
    
    <!-- Decorative Crown/Trophy Icon Header -->
    <div class="bg-gradient-to-br from-primary to-primary-light p-8 text-center text-white relative">
      <div class="absolute top-4 right-4">
