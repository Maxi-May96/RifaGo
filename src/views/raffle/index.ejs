<!-- src/views/raffle/index.ejs -->
<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 9999px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>

<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6 py-4">
  <!-- Header Title -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-slate-200/60 pb-5 gap-4">
    <div class="space-y-1">
      <span class="inline-flex items-center space-x-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-primary/10 text-primary border border-primary/20">
        <span>🎟️</span> <span>Catálogo Completo</span>
      </span>
      <h1 class="text-3xl font-black text-dark tracking-tight">Explorar Sorteos</h1>
      <p class="text-xs text-slate-400 font-semibold">Participa en sorteos activos organizados por la comunidad.</p>
    </div>
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider bg-white border border-slate-100 px-3.5 py-2 rounded-xl shadow-sm">
      Encontrados: <%= raffles.length %> sorteo<%= raffles.length !== 1 ? 's' : '' %>
    </div>
  </div>

  <!-- Two-Column Catalog Layout using robust Flexbox -->
  <div class="flex flex-col lg:flex-row gap-8 items-start w-full">
    
    <!-- LEFT SIDEBAR: Filters Pane -->
    <div class="w-full lg:w-1/4 lg:sticky lg:top-24 space-y-4 flex-shrink-0">
      <div class="bg-white rounded-3xl border border-borderCustom shadow-sm p-6 space-y-5">
        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
          <h3 class="text-xs font-black text-dark uppercase tracking-wider flex items-center space-x-2">
            <span>⚙️</span> <span>Filtros</span>
          </h3>
          <a href="/raffles" class="text-[10px] font-bold text-slate-400 hover:text-slate-600 transition-all">
            Limpiar todo
          </a>
        </div>

        <form action="/raffles" method="GET" id="filterForm" class="space-y-4">
          <!-- Keyword -->
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider">Palabra clave</label>
            <div class="relative flex items-center bg-slate-50 border border-slate-200/80 rounded-xl px-3 py-2">
              <span class="text-slate-400 text-xs mr-2">🔍</span>
              <input type="text" name="q" value="<%= filters.q || '' %>" placeholder="Ej: iPhone, Moto..." 
                     class="w-full text-xs font-semibold bg-transparent border-none outline-none text-dark placeholder-slate-400 focus:ring-0 p-0">
            </div>
          </div>

          <!-- Location Search -->
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider">Dirección / Ciudad</label>
            <div class="relative flex items-center bg-slate-50 border border-slate-200/80 rounded-xl px-3 py-2 mb-2">
              <span class="text-slate-400 text-xs mr-2">📍</span>
              <input type="text" id="addressSearchInput" placeholder="Buscar dirección..." 
                     class="w-full text-xs font-semibold bg-transparent border-none outline-none text-dark placeholder-slate-400 focus:ring-0 p-0">
              
              <input type="hidden" name="latitude" id="filter-latitude" value="<%= filters.latitude || '' %>">
              <input type="hidden" name="longitude" id="filter-longitude" value="<%= filters.longitude || '' %>">
            </div>

            <!-- Real-time Location Button -->
            <button type="button" id="locationBtn" onclick="getCurrentLocation()"
                    class="w-full py-2 bg-primary/10 hover:bg-primary/20 text-primary border border-primary/20 text-[10px] rounded-xl transition-all font-black flex items-center justify-center space-x-1">
              <span>🎯</span> <span>Usar mi ubicación en vivo</span>
            </button>
          </div>

          <!-- Radius / Distance Selection -->
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider">Distancia Máxima</label>
            <select name="radius" class="w-full px-3 py-2 text-xs rounded-xl border border-slate-200 bg-slate-50 text-slate-700 font-semibold outline-none focus:ring-1 focus:ring-primary cursor-pointer">
              <option value="5" <%= filters.radius == 5 ? 'selected' : '' %>>A menos de 5 km</option>
              <option value="10" <%= filters.radius == 10 ? 'selected' : '' %>>A menos de 10 km</option>
              <option value="25" <%= filters.radius == 25 || !filters.radius ? 'selected' : '' %>>A menos de 25 km</option>
              <option value="50" <%= filters.radius == 50 ? 'selected' : '' %>>A menos de 50 km</option>
              <option value="100" <%= filters.radius == 100 ? 'selected' : '' %>>A menos de 100 km</option>
              <option value="200" <%= filters.radius == 200 ? 'selected' : '' %>>A menos de 200 km</option>
            </select>
          </div>

          <!-- Divider -->
          <div class="border-t border-slate-100 my-2"></div>

          <!-- Country -->
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider">País</label>
            <input type="text" name="country" value="<%= filters.country || '' %>" placeholder="Ej: Argentina" 
                   class="w-full px-3 py-2 text-xs rounded-xl border border-slate-200 bg-slate-50 text-dark font-semibold outline-none focus:ring-1 focus:ring-primary">
          </div>

          <!-- Province -->
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider">Provincia</label>
            <input type="text" name="province" value="<%= filters.province || '' %>" placeholder="Ej: Buenos Aires" 
                   class="w-full px-3 py-2 text-xs rounded-xl border border-slate-200 bg-slate-50 text-dark font-semibold outline-none focus:ring-1 focus:ring-primary">
          </div>

          <!-- Search Button -->
          <button type="submit" class="w-full py-3 bg-dark hover:bg-slate-800 text-white font-extrabold text-xs rounded-xl transition-all shadow-md mt-4">
            Aplicar Filtros 🔍
          </button>
        </form>
      </div>
    </div>

    <!-- RIGHT CONTENT: Catalog Grid -->
    <div class="w-full lg:w-3/4 space-y-6">
      <% if (raffles.length === 0) { %>
        <!-- Empty State -->
        <div class="bg-white rounded-[2rem] p-12 border border-borderCustom shadow-sm text-center max-w-xl mx-auto space-y-4 my-10">
          <span class="text-5xl block animate-pulse">🏝️</span>
          <h4 class="text-base font-black text-dark">No se encontraron sorteos</h4>
          <p class="text-xs text-slate-500 max-w-sm mx-auto leading-relaxed">
            Prueba ampliando el radio de búsqueda, modificando tu ubicación o limpiando los filtros activos.
          </p>
          <a href="/raffles" class="inline-block px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-xs shadow-md transition-all">
            Limpiar Todos los Filtros
          </a>
        </div>
      <% } else { %>
        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% raffles.forEach(r => { 
               const soldPercent = Math.round((r.soldTickets / r.totalTickets) * 100) || 0;
               const categoryName = r.category ? r.category.name : 'Sorteo';
               const categoryEmoji = categoryName.toLowerCase().includes('moto') || categoryName.toLowerCase().includes('vehic') ? '🏍️' : 
                                     categoryName.toLowerCase().includes('tecno') ? '💻' : 
                                     categoryName.toLowerCase().includes('efect') || categoryName.toLowerCase().includes('dinero') ? '💵' : '🎟️';
          %>
            <!-- Premium Ticket Card -->
            <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col justify-between relative w-full">
              <div>
                <!-- Cover Image & Badges -->
                <div class="h-48 relative overflow-hidden bg-slate-50">
                  <% if (r.image) { %>
                    <img src="<%= r.image %>" alt="<%= r.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
                  <% } else { %>
                    <div class="w-full h-full bg-gradient-to-br from-primary/10 to-primary-light/5 flex items-center justify-center text-slate-300 relative">
                      <span class="text-5xl opacity-40"><%= categoryEmoji %></span>
                    </div>
                  <% } %>

                  <!-- Category Badge Overlay -->
                  <div class="absolute top-4 left-4 z-10">
                    <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-wider bg-white/90 backdrop-blur-md text-dark border border-slate-200/50 shadow-sm">
                      <%= categoryEmoji %> <%= categoryName %>
                    </span>
                  </div>

                  <!-- Distance Badge Overlay -->
                  <% if (r.distance !== undefined && r.distance !== null) { %>
                    <div class="absolute bottom-4 right-4 z-10">
                      <span class="px-2.5 py-1 rounded-full text-[9px] font-black bg-slate-900/80 backdrop-blur-md text-primary-light border border-slate-800 shadow-sm flex items-center space-x-1">
                        <span>📍</span> <span>a <%= r.distance.toFixed(1) %> km</span>
                      </span>
                    </div>
                  <% } %>
                </div>

                <!-- Perforation divider with ticket notches -->
                <div class="relative flex items-center justify-between my-1 px-1">
                  <div class="absolute -left-2 w-4 h-4 bg-grayCustom rounded-full border-r border-slate-100"></div>
                  <div class="w-full border-t border-dashed border-slate-200"></div>
                  <div class="absolute -right-2 w-4 h-4 bg-grayCustom rounded-full border-l border-slate-100"></div>
                </div>

                <!-- Body Details -->
                <div class="p-5 pb-2 space-y-3">
                  <div class="flex items-center justify-between text-[9px] font-bold text-slate-400 uppercase tracking-wider">
                    <span>📍 <%= r.city %></span>
                    <span>Sorteo: <%= new Date(r.drawDate).toLocaleDateString('es-AR') %></span>
                  </div>

                  <div class="space-y-1">
                    <h3 class="text-base font-extrabold text-dark leading-snug group-hover:text-primary transition-colors line-clamp-1">
                      <a href="/raffles/<%= r.slug || r._id %>"><%= r.title %></a>
                    </h3>
                    <p class="text-xs text-slate-500 line-clamp-2 leading-relaxed h-8">
                      <%= r.motivo %>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Footer details: Progress and Price -->
              <div class="p-5 pt-0 mt-auto space-y-4">
                <!-- Sales Progress Bar -->
                <div class="space-y-1.5">
                  <div class="flex justify-between items-center text-[9px] font-black text-slate-400 uppercase tracking-wider">
                    <span>Progreso</span>
                    <span class="text-dark font-black"><%= soldPercent %> %</span>
                  </div>
                  <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden border border-slate-200/20">
                    <div class="h-full bg-gradient-to-r from-primary to-primary-light transition-all duration-300" style="width: <%= soldPercent %>%;"></div>
                  </div>
                </div>

                <!-- Price and CTA -->
                <div class="flex items-center justify-between pt-1 border-t border-slate-50">
                  <div class="flex flex-col">
                    <span class="text-[8px] text-slate-400 font-bold uppercase tracking-wider">Valor Ticket</span>
                    <span class="text-base font-black text-dark">$<%= r.ticketPrice.toLocaleString('es-AR') %></span>
                  </div>

                  <a href="/raffles/<%= r.slug || r._id %>" 
                     class="px-4 py-2.5 bg-dark hover:bg-primary hover:text-white text-white font-extrabold text-[10px] uppercase tracking-wider rounded-xl shadow-sm transition-all flex items-center space-x-1.5">
                    <span>Participar</span> <span>⚡</span>
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>
</div>

<!-- Autocomplete and Geolocation Script -->
<% if (googleMapsApiKey) { %>
  <script>
    let autocomplete;

    function getCurrentLocation() {
      const btn = document.getElementById('locationBtn');
      const addressInput = document.getElementById('addressSearchInput');
      const latInput = document.getElementById('filter-latitude');
      const lngInput = document.getElementById('filter-longitude');
      
      if (!navigator.geolocation) {
        alert('Geolocalización no es soportada por tu navegador.');
        return;
      }
      
      btn.innerHTML = '⌛ Obteniendo ubicación...';
      btn.disabled = true;

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;
          latInput.value = lat;
          lngInput.value = lng;
          
          btn.innerHTML = '✅ Ubicación Obtenida';
          btn.disabled = false;
          addressInput.value = 'Mi ubicación actual';
          
          // Submit form automatically on location fetch
          document.getElementById('filterForm').submit();
        },
        (error) => {
          console.error(error);
          btn.innerHTML = '❌ Error al obtener';
          btn.disabled = false;
          alert('No pudimos acceder a tu ubicación. Por favor ingresa una dirección manualmente.');
        },
        { enableHighAccuracy: true, timeout: 7000, maximumAge: 0 }
      );
    }

    function initAutocomplete() {
      const input = document.getElementById('addressSearchInput');
      if (!input) return;

      autocomplete = new google.maps.places.Autocomplete(input, {
        fields: ['geometry', 'formatted_address']
      });

      autocomplete.addListener('place_changed', () => {
        const place = autocomplete.getPlace();
        if (!place.geometry || !place.geometry.location) {
          console.warn("Dirección seleccionada no contiene coordenadas.");
          return;
        }

        // Set hidden inputs
        document.getElementById('filter-latitude').value = place.geometry.location.lat();
        document.getElementById('filter-longitude').value = place.geometry.location.lng();
      });

      // Clear coordinates if user clears input completely
      input.addEventListener('input', () => {
        if (!input.value.trim()) {
          document.getElementById('filter-latitude').value = '';
          document.getElementById('filter-longitude').value = '';
        }
      });
      
      // Prevent enter key submitting form prematurely
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
        }
      });
    }

    window.addEventListener('DOMContentLoaded', () => {
      // Restore place name label if coordinate is present
      const latVal = document.getElementById('filter-latitude').value;
      const lngVal = document.getElementById('filter-longitude').value;
      const addressInput = document.getElementById('addressSearchInput');
      if (latVal && lngVal && !addressInput.value) {
        addressInput.value = 'Ubicación seleccionada';
      }

      // Load Google Places Autocomplete
      if (typeof google !== 'undefined' && google.maps && google.maps.places) {
        initAutocomplete();
      } else {
        const checkMapInterval = setInterval(() => {
          if (typeof google !== 'undefined' && google.maps && google.maps.places) {
            clearInterval(checkMapInterval);
            initAutocomplete();
          }
        }, 200);
      }
    });
  </script>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&libraries=places" async defer></script>
<% } %>
