<div class="max-w-xl mx-auto my-16 px-4">
  <div class="bg-white rounded-3xl border border-slate-200/80 shadow-2xl overflow-hidden animate-fade-in text-center">
    
    <!-- Animated Banner -->
    <div class="bg-gradient-to-r from-emerald-500 to-teal-500 py-12 text-white relative">
      <div class="w-20 h-20 rounded-full bg-white/20 flex items-center justify-center text-4xl mx-auto animate-bounce shadow-inner">
        🎉
      </div>
      <h1 class="text-3xl font-black mt-6 tracking-tight">¡Compra Exitosa!</h1>
      <p class="text-xs opacity-90 mt-1 uppercase tracking-wider font-extrabold">Tus números han sido asignados</p>
    </div>

    <div class="p-8 space-y-8">
      
      <!-- Summary Info Card -->
      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100/60 divide-y divide-slate-100 text-sm font-semibold">
        <div class="pb-3 flex justify-between">
          <span class="text-slate-400 font-bold text-xs uppercase tracking-wider">Sorteo</span>
          <span class="text-dark"><%= raffle.title %></span>
        </div>
        <div class="py-3 flex justify-between">
          <span class="text-slate-400 font-bold text-xs uppercase tracking-wider">Monto Pagado</span>
          <span class="text-emerald-600 font-black">$<%= purchase.amount.toLocaleString('es-AR') %></span>
        </div>
        <div class="pt-3 flex justify-between">
          <span class="text-slate-400 font-bold text-xs uppercase tracking-wider">Operación ID</span>
          <span class="text-slate-500 text-xs font-mono font-medium"><%= purchase.paymentId || purchase._id %></span>
        </div>
      </div>

      <!-- Ticket Numbers -->
      <div class="space-y-3">
        <h3 class="font-extrabold text-dark text-xs uppercase tracking-wider text-primary">Tus Números de Boleto</h3>
        <div class="flex flex-wrap justify-center gap-2">
          <% purchase.numbers.forEach(num => { %>
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-50 to-teal-50 border border-emerald-100 shadow-sm flex flex-col items-center justify-center relative">
              <span class="text-[9px] font-black text-emerald-600 uppercase tracking-widest leading-none">NRO</span>
              <span class="font-black text-dark text-sm mt-0.5">#<%= num %></span>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Footer Buttons -->
      <div class="space-y-3 pt-4 border-t border-slate-100">
        <a href="/raffles/<%= raffle.slug %>" class="w-full block bg-primary hover:bg-primary-light text-white font-extrabold py-3.5 rounded-2xl shadow-md transition-all text-xs uppercase tracking-wider">
          Volver al Sorteo
        </a>
        <a href="/raffles/myraffles" class="w-full block bg-slate-100 hover:bg-slate-200 text-slate-700 font-extrabold py-3.5 rounded-2xl transition-all text-xs uppercase tracking-wider">
          Ir a Mis Sorteos / Compras
        </a>
      </div>
    </div>
  </div>
</div>
